{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://criptojackpot.com",
      "https://www.criptojackpot.com",
      "https://app.criptojackpot.com"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=cryptojackpot_wallet_db;Username=postgres;Password=postgres;"
  },
  "JwtSettings": {
    "SecretKey": "super_secret_key_crypto_jackpot_distributed_2025!",
    "Issuer": "CriptoJackpotIdentity",
    "Audience": "CriptoJackpotApp",
    "ExpirationInMinutes": 60
  },
  "CookieSettings": {
    "Domain": null,
    "SecureOnly": false,
    "SameSite": "Lax",
    "AccessTokenCookieName": "access_token",
    "RefreshTokenCookieName": "refresh_token",
    "Path": "/"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "DefaultPartitions": 1,
    "DefaultReplicationFactor": 1
  },
  "OpenTelemetry": {
    "Enabled": true,
    "Endpoint": "http://localhost:4317"
  },
  "GrpcServices": {
    "IdentityAddress": "http://localhost:5010"
  }
}

